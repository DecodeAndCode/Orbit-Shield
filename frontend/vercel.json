{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install --no-audit --prefer-offline",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://orbit-shield-api.fly.dev/api/:path*" }
  ]
}
